# Backend production secrets. Do not commit real values.
DB_URL="jdbc:postgresql://db.hqlhidqnzprzigmzyuub.supabase.co:5432/postgres"
DB_USERNAME="postgres"
DB_PASSWORD="MY_DB_PASSWORD"
JWT_SECRET="CHANGE_ME_TO_A_LONG_RANDOM_SECRET"
JWT_EXPIRATION_SECONDS="604800"
CORS_ALLOWED_ORIGINS="http://localhost:3000,https://REPLACE_WITH_WEB_DOMAIN"
GEMINI_API_KEY="MY_GEMINI_API_KEY"
